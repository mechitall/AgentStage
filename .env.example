# Agent Stage Environment Configuration
# Copy this file to .env and fill in your API keys

# ========================================
# REQUIRED - Core AI Intelligence
# ========================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# RECOMMENDED - Professional Voice Synthesis  
# ========================================
# Get from: https://elevenlabs.io/app/settings/api-keys
# Adds Hollywood-quality voices for each advisor + BBC-style event narration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ========================================
# OPTIONAL - Real-World Intelligence Enhancement
# ========================================
# Get from: https://platform.aci.dev/
# Enables advisors to research current events and technical solutions
ACI_API_KEY=your_aci_api_key_here
ACI_LINKED_ACCOUNT_OWNER_ID=your_linked_account_owner_id_here

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
GAME_MODE=oval_office

# ========================================
# FUTURE INTEGRATIONS (Optional)
# ========================================
# AI_ACOUSTICS_API_KEY=your_ai_acoustics_key_here

# ========================================
# SETUP INSTRUCTIONS:
# ========================================
# 1. REQUIRED: Get OpenAI API key for core AI functionality
# 2. RECOMMENDED: Get ElevenLabs key for professional voices
# 3. OPTIONAL: Get ACI.dev key for real-world intelligence
# 4. Copy this file to .env in the project root
# 5. Run: npm install && npm run build && npm start
# 6. Open: http://localhost:3000
#
# The system works in multiple modes:
# - OpenAI only: Text-based gameplay with AI intelligence
# - + ElevenLabs: Professional voice synthesis for each advisor
# - + ACI.dev: Real-world research and current events integration
# - All three: Complete professional experience with voices + intelligence
